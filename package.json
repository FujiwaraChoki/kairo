{
  "name": "kairo",
  "version": "1.0.0",
  "description": "AI-powered Telegram bot built on the Claude Agent SDK with integrations for WhatsApp, Gmail, Spotify, Notion, and more",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "start": "node --env-file=.env --import tsx src/index.ts",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@hapi/boom": "^10.0.1",
    "@notionhq/notion-mcp-server": "^2.1.0",
    "@types/hapi__boom": "^9.0.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "exa-js": "^2.4.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "module": "src/index.ts",
  "pnpm": {
    "overrides": {
      "sharp": "npm:@aspect-build/empty-package@1.0.0"
    }
  }
}
