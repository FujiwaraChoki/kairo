# Required — Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Bot name — used in the system prompt and logs
BOT_NAME=Kairo

# Optional — override the default system prompt entirely
# Priority: SYSTEM_PROMPT env var > SOUL.md file > built-in default
# SYSTEM_PROMPT=You are a pirate assistant. Respond in pirate speak.

# Token budget for conversation context (default: 16000)
# MAX_CONTEXT_TOKENS=16000

# Number of recent messages protected from compaction (default: 6)
# PROTECTED_MESSAGES=6

# Custom path for the SQLite database (default: data/kairo.db)
# DB_PATH=data/kairo.db

# Set to "true" to respond in group chats (default: DMs only)
# ENABLE_GROUPS=false

# Exa API key for web search (optional — bot works without it)
# EXA_API_KEY=your-exa-api-key-here

# Log level: "debug" | "info" | "warn" | "error" | "fatal" | "silent" (default: "info")
# LOG_LEVEL=info

# Notion internal integration token (optional — https://www.notion.so/profile/integrations)
# NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxx

# Spotify (optional — https://developer.spotify.com/dashboard)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# SPOTIFY_CALLBACK_PORT=8888
